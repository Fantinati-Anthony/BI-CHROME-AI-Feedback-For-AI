{
  "name": "my-feedbacks",
  "version": "2.4.0",
  "private": true,
  "description": "My-Feedbacks — Local-first feedback bridge between developers and their clients (Chrome MV3 extension).",
  "homepage": "https://my-feedbacks.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Fantinati-Anthony/my-feedbacks-extension"
  },
  "license": "MIT",
  "scripts": {
    "test":          "vitest run",
    "test:watch":    "vitest",
    "test:coverage": "vitest run --coverage",
    "lint":          "eslint . --ext .js",
    "i18n:check":    "node scripts/i18n-coverage.mjs",
    "i18n:strict":   "node scripts/i18n-coverage.mjs --strict",
    "build":         "node scripts/build.mjs",
    "build:watch":   "node scripts/build.mjs --watch",
    "package":       "node scripts/package.mjs",
    "package:dev":   "node scripts/package.mjs --dev"
  },
  "devDependencies": {
    "vitest":              "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0",
    "jsdom":               "^24.0.0",
    "eslint":              "^8.57.0",
    "esbuild":             "^0.21.0",
    "fake-indexeddb":      "^5.0.2",
    "@types/chrome":       "^0.0.268",
    "typescript":          "^5.4.5"
  }
}
