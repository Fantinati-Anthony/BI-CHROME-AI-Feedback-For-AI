# My-Feedbacks Bridge — nginx hardening
#
# Include this file from your existing server block, OR adapt it as a
# standalone server block. Drop next to myfb-bridge.php.
#
# Usage (option A — included from existing site) :
#
#   server {
#     server_name example.com;
#     root /var/www/example.com;
#     …
#     include /var/www/example.com/myfb-bridge.nginx.conf;
#   }
#
# Usage (option B — paste the contents into your server block).
#
# Tested with nginx 1.18+ and PHP-FPM 8.2.

# ── Block direct read of runtime files ─────────────────────────────
# Generated by the setup wizard ; contain secret HMAC + DB credentials
# + audit log + nonce store. Must NEVER be served as static text.
location ~ /myfb-bridge\.(config\.php|audit\.log|nonces|nonces\.tmp)$ {
  deny all;
  return 404;
}

# ── Route the bridge entrypoint to PHP-FPM ─────────────────────────
location = /myfb-bridge.php {
  # Adjust the socket path to match your PHP-FPM pool config.
  fastcgi_pass         unix:/run/php/php8.2-fpm.sock;
  fastcgi_index        myfb-bridge.php;
  include              fastcgi_params;
  fastcgi_param        SCRIPT_FILENAME  $document_root$fastcgi_script_name;

  # Tighten timeouts — `meta` returns in <100ms, `schema_md` rarely
  # over 2s on a fresh DB. 10s gives plenty of slack for cold caches.
  fastcgi_read_timeout 10s;

  # Body limit matches the bridge's own 32 KB cap on $raw_input.
  client_max_body_size 64k;
}

# ── Optional : force HTTPS on the bridge URL ───────────────────────
# Uncomment if your site supports both http and https. The bridge ships
# `Access-Control-Allow-Origin: *` so HTTPS is mandatory for production
# use (TLS is the only transport-level secrecy you have).
# if ($scheme = http) {
#   return 301 https://$host$request_uri;
# }
