<?xml version="1.0" encoding="UTF-8"?>
<!--
  My-Feedbacks Bridge — IIS web.config

  Drop this file next to myfb-bridge.php in the site's webroot.
  Requires :
    - IIS 7+
    - PHP installed via PHP Manager (or use the Microsoft PHP installer)
    - URL Rewrite module (`Install-WindowsFeature Web-Url-Rewrite`)

  Tested with IIS 10 + PHP 8.2.
-->
<configuration>
  <system.webServer>

    <!-- ── Block direct read of runtime files ──────────────────
         Generated by the setup wizard ; contain secret HMAC +
         DB credentials + audit log + nonce store. Must NEVER be
         served as static text. -->
    <security>
      <requestFiltering>
        <denyUrlSequences>
          <add sequence="myfb-bridge.config.php" />
          <add sequence="myfb-bridge.audit.log"  />
          <add sequence="myfb-bridge.nonces"     />
          <add sequence="myfb-bridge.nonces.tmp" />
        </denyUrlSequences>
      </requestFiltering>
    </security>

    <!-- Optional : explicit MIME mapping (most IIS installs already
         have this, harmless if redundant). -->
    <staticContent>
      <remove fileExtension=".log" />
      <mimeMap fileExtension=".log" mimeType="text/plain" />
    </staticContent>

    <!-- ── Optional : force HTTPS on the bridge URL ───────────
         Uncomment when your binding has a valid TLS cert. -->
    <!--
    <rewrite>
      <rules>
        <rule name="Force HTTPS for bridge" stopProcessing="true">
          <match url="^myfb-bridge\.php$" />
          <conditions>
            <add input="{HTTPS}" pattern="^OFF$" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}{REQUEST_URI}"
                  redirectType="Permanent" />
        </rule>
      </rules>
    </rewrite>
    -->

    <!-- ── Cap the body size (the bridge itself enforces 32 KB) ── -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="65536" />
      </requestFiltering>
    </security>

  </system.webServer>
</configuration>
