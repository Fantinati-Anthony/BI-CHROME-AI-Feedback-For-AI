{
  "manifest_version": 3,
  "name": "BI Chrome AI Feedback",
  "version": "0.2.0",
  "description": "Capture des feedbacks visuels (sélecteur d'élément CSS) + vocaux (speech-to-text) pour les transmettre à une IA (Claude Code).",
  "permissions": ["activeTab", "storage", "clipboardWrite", "sidePanel", "offscreen"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "BI AI Feedback (Alt+Shift+F)"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "run_at": "document_idle",
      "js": [
        "content/css-selector.js",
        "content/element-selector.js",
        "content/screenshot.js",
        "content/screenshot-editor.js",
        "content/main.js"
      ]
    }
  ],
  "commands": {
    "toggle-sidebar": {
      "suggested_key": { "default": "Alt+Shift+F" },
      "description": "Ouvrir le panneau latéral BIAIF"
    },
    "toggle-picker": {
      "suggested_key": { "default": "Alt+Shift+E" },
      "description": "Activer/désactiver le sélecteur d'élément"
    },
    "toggle-mic": {
      "suggested_key": { "default": "Alt+Shift+M" },
      "description": "Démarrer/arrêter le micro (speech-to-text)"
    },
    "copy-prompt": {
      "suggested_key": { "default": "Alt+Shift+C" },
      "description": "Copier le prompt formaté pour l'IA"
    }
  }
}
