{
  "manifest_version": 3,
  "name": "BI Chrome AI Feedback",
  "version": "0.5.0",
  "description": "Capture des feedbacks visuels (sélecteur d'élément CSS) + vocaux (speech-to-text) pour les transmettre à une IA (Claude Code).",
  "author": "Anthony Fantinati",
  "minimum_chrome_version": "114",
  "permissions": ["activeTab", "storage", "clipboardWrite", "sidePanel", "contextMenus"],
  "host_permissions": ["<all_urls>"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' http://127.0.0.1:* http://localhost:*; img-src 'self' data: blob:"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "BI AI Feedback (Alt+Shift+F)"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "run_at": "document_start",
      "world": "MAIN",
      "js": ["content/page-error-monitor.js"]
    },
    {
      "matches": ["<all_urls>"],
      "run_at": "document_start",
      "js": ["shared/constants.js", "shared/config.js", "shared/utils.js", "shared/logger.js", "shared/dom.js", "content/error-bridge.js"]
    },
    {
      "matches": ["<all_urls>"],
      "run_at": "document_idle",
      "js": [
        "shared/constants.js",
        "shared/config.js",
        "shared/utils.js",
        "shared/logger.js",
        "shared/dom.js",
        "shared/ai-adapters.js",
        "content/css-selector.js",
        "content/element-selector.js",
        "content/screenshot.js",
        "content/screenshot-editor.js",
        "content/main.js",
        "content/inject.js"
      ]
    },
    {
      "matches": ["<all_urls>"],
      "run_at": "document_idle",
      "js": [
        "shared/constants.js",
        "shared/config.js",
        "shared/utils.js",
        "shared/logger.js",
        "shared/dom.js",
        "shared/ai-adapters.js",
        "content/textarea-injector.js"
      ]
    },
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://grok.com/*",
        "https://x.com/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://chat.mistral.ai/*",
        "https://mistral.ai/*",
        "https://chat.deepseek.com/*"
      ],
      "run_at": "document_idle",
      "js": [
        "shared/constants.js",
        "shared/config.js",
        "shared/utils.js",
        "shared/logger.js",
        "shared/dom.js",
        "shared/ai-adapters.js",
        "content/ai-watcher.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["PRIVACY.md"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "toggle-sidebar": {
      "suggested_key": { "default": "Alt+Shift+F" },
      "description": "Ouvrir le panneau latéral BIAIF"
    },
    "toggle-picker": {
      "suggested_key": { "default": "Alt+Shift+E" },
      "description": "Activer/désactiver le sélecteur d'élément"
    },
    "toggle-mic": {
      "suggested_key": { "default": "Alt+Shift+M" },
      "description": "Démarrer/arrêter le micro (speech-to-text)"
    },
    "copy-prompt": {
      "suggested_key": { "default": "Alt+Shift+C" },
      "description": "Copier le prompt formaté pour l'IA"
    }
  }
}
