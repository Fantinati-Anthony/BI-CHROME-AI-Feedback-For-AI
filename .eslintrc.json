{
  "root": true,
  "env": {
    "browser": true,
    "es2022": true,
    "webextensions": true,
    "serviceworker": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "script"
  },
  "globals": {
    "BIAIF": "readonly",
    "BIAIFi18n": "readonly",
    "BIAIFExport": "writable",
    "BIAIFRenderer": "writable",
    "BIAIFSession": "writable",
    "BIAIFStorage": "writable",
    "BIAIFSpeech": "writable",
    "BIAIFToast": "writable",
    "BIAIFUndo": "writable",
    "BIAIFWizard": "writable",
    "BIAIFSelector": "readonly",
    "BIAIFScreenshot": "readonly",
    "BIAIFElementSelector": "readonly",
    "chrome": "readonly"
  },
  "rules": {
    "no-unused-vars": ["warn", { "args": "none", "varsIgnorePattern": "^_" }],
    "no-console": "off",
    "no-empty": ["error", { "allowEmptyCatch": true }],
    "eqeqeq": ["error", "smart"],
    "no-implicit-globals": "warn",
    "prefer-const": "warn",
    "no-var": "off"
  },
  "ignorePatterns": [
    "vscode-extension/node_modules/**",
    "**/*.min.js"
  ]
}
